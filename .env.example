# Copy this file to .env.local for local dev:
#   copy .env.example .env.local
#
# For GitHub Pages live deploy, add the same two VITE_* values as repository Secrets
# (Settings → Secrets and variables → Actions).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard

# Find these in Supabase: Project Settings → API
#   Project URL  → VITE_SUPABASE_URL
#   anon public  → VITE_SUPABASE_ANON_KEY

# Zapier RPC auth (stored in DB, not in this file):
#   UPDATE app_settings SET value = 'your-secret-key' WHERE key = 'zapier_api_key';
